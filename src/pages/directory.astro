---
import Layout from '../layouts/Layout.astro';

const resources = [
  // Crisis
  {
    name: "Lifeline",
    category: "crisis",
    description: "24/7 crisis support and suicide prevention. Phone, text, and online chat available for anyone in distress.",
    cost: "Free",
    url: "https://www.lifeline.org.au/",
    cta: "Call 13 11 14",
    note: "Available 24/7",
    au: true,
    affiliate: false,
  },
  {
    name: "Beyond Blue",
    category: "crisis",
    description: "Anxiety and depression support. Phone, online chat, and extensive resources for mental health concerns.",
    cost: "Free",
    url: "https://www.beyondblue.org.au/",
    cta: "Call 1300 22 4636",
    note: "24/7 phone & chat",
    au: true,
    affiliate: false,
  },
  {
    name: "13YARN",
    category: "crisis",
    description: "Crisis support for Aboriginal and Torres Strait Islander peoples. First-of-its-kind national 24/7 line.",
    cost: "Free",
    url: "https://www.13yarn.org.au/",
    cta: "Call 13 92 76",
    note: "24/7, for mob",
    au: true,
    affiliate: false,
  },
  {
    name: "Kids Helpline",
    category: "crisis",
    description: "Free, private counselling for young people aged 5–25. Phone, video, and chat available.",
    cost: "Free",
    url: "https://kidshelpline.com.au/",
    cta: "Call 1800 55 1800",
    note: "24/7 for under 25s",
    au: true,
    affiliate: false,
  },
  {
    name: "MensLine Australia",
    category: "crisis",
    description: "24/7 telephone and online support for men with mental health or relationship concerns.",
    cost: "Free",
    url: "https://mensline.org.au/",
    cta: "Call 1300 78 99 78",
    note: "24/7",
    au: true,
    affiliate: false,
  },

  // Therapy
  {
    name: "BetterHelp",
    category: "therapy",
    description: "Licensed Australian therapists via video, phone, or messaging. Cancel anytime. Start within days.",
    cost: "From ~$60/week",
    url: "https://payhip.com/b/9sc5L", // placeholder affiliate link
    cta: "Get Started",
    note: "40% recurring commission",
    au: true,
    affiliate: true,
    affiliateNote: "We may earn a commission — our review is still honest.",
  },
  {
    name: "Talkspace",
    category: "therapy",
    description: "Text, audio, and video therapy with Australian-registered psychologists. Flexible plans.",
    cost: "From ~$49/week",
    url: "https://www.talkspace.com/",
    cta: "Start Therapy",
    note: "Matched to your needs",
    au: true,
    affiliate: true,
  },
  {
    name: "MindSpot",
    category: "therapy",
    description: "Free digital mental health clinic. Short courses and therapist connections for anxiety and depression.",
    cost: "Free",
    url: "https://www.mindspot.org.au/",
    cta: "Take Assessment",
    note: "Government funded",
    au: true,
    affiliate: false,
  },
  {
    name: "Psychology Today",
    category: "therapy",
    description: "Find a registered psychologist in your area. Filter by specialty, location, and cost.",
    cost: "Varies",
    url: "https://www.psychologytoday.com.au/",
    cta: "Find a Psychologist",
    note: "Bulk billing may be available",
    au: true,
    affiliate: false,
  },
  {
    name: "Monash Health Psychology",
    category: "therapy",
    description: "Bulk-billed psychology through Medicare. Requires GP mental health care plan referral.",
    cost: "Free (with GP referral)",
    url: "https://www.monashhealth.org/psychology/",
    cta: "Learn More",
    note: "Medicare required",
    au: true,
    affiliate: false,
  },

  // Apps
  {
    name: "Calm",
    category: "apps",
    description: "Meditation, sleep stories, and breathing exercises. 100+ soundscapes and guided sessions.",
    cost: "Free / ~$70/year",
    url: "https://www.calm.com/",
    cta: "Download Free",
    note: "iOS & Android",
    au: true,
    affiliate: true,
  },
  {
    name: "Headspace",
    category: "apps",
    description: "Guided meditation and mindfulness. Science-backed programs for focus, sleep, and stress.",
    cost: "Free / ~$70/year",
    url: "https://www.headspace.com/",
    cta: "Try Free",
    note: "iOS & Android",
    au: true,
    affiliate: true,
  },
  {
    name: "ReachOut",
    category: "apps",
    description: "Free anonymous support for 14–25 year olds. Forums, articles, and coached programs.",
    cost: "Free",
    url: "https://reachout.au/",
    cta: "Get Support",
    note: "Under 25s",
    au: true,
    affiliate: false,
  },
  {
    name: "Wysa",
    category: "apps",
    description: "AI-powered mental health chatbot plus optional human therapy. Good for consistent check-ins.",
    cost: "Free / ~$40/mo",
    url: "https://www.wysa.com/",
    cta: "Try Wysa",
    note: "Anonymous",
    au: true,
    affiliate: false,
  },
  {
    name: "Sleepio",
    category: "apps",
    description: "Clinically-proven digital sleep improvement program. 6-week course backed by research.",
    cost: "Free (AU residents)",
    url: "https://www.sleepio.com/",
    cta: "Start Free",
    note: "Evidence-based",
    au: true,
    affiliate: false,
  },

  // Free / Low-cost
  {
    name: "headspace",
    category: "free",
    description: "Mental health organisation for young people (12–25). Headspace centres across Australia + digital services.",
    cost: "Free",
    url: "https://headspace.org.au/",
    cta: "Find a Centre",
    note: "Youth (12–25)",
    au: true,
    affiliate: false,
  },
  {
    name: "Butterfly Foundation",
    category: "free",
    description: "Support for Australians experiencing eating disorders. Helpline, online programs, and community.",
    cost: "Free",
    url: "https://www.butterfly.org.au/",
    cta: "Get Support",
    note: "Helpline available",
    au: true,
    affiliate: false,
  },
  {
    name: " Sane Australia",
    category: "free",
    description: "Mental health information and peer support for those affected by complex mental health issues.",
    cost: "Free",
    url: "https://www.sane.org/",
    cta: "Get Support",
    note: "Peer forums + helpline",
    au: true,
    affiliate: false,
  },
  {
    name: "MoodGym",
    category: "free",
    description: "Free cognitive behavioural therapy (CBT) program for depression and anxiety. Self-paced, anonymous.",
    cost: "Free",
    url: "https://moodgym.com.au/",
    cta: "Start Free",
    note: "Evidence-based CBT",
    au: true,
    affiliate: false,
  },
  {
    name: "This Way Up",
    category: "free",
    description: "Free and low-cost courses for anxiety and depression developed by psychiatrists. Short and structured.",
    cost: "Free / ~$49",
    url: "https://thiswayup.org.au/",
    cta: "Browse Courses",
    note: "Clinically developed",
    au: true,
    affiliate: false,
  },
];

const filters = [
  { id: "all", label: "All Resources" },
  { id: "crisis", label: "Crisis Support" },
  { id: "therapy", label: "Therapy" },
  { id: "apps", label: "Apps" },
  { id: "free", label: "Free / Low-Cost" },
];

const categoryColors = {
  crisis: "#DC2626",
  therapy: "#4F46E5",
  apps: "#059669",
  free: "#D97706",
};
---

<Layout>
  <div class="directory-page">
    <!-- Hero -->
    <div class="hero">
      <div class="container">
        <span class="section-label">Resources</span>
        <h1>AU Mental Health Directory</h1>
        <p>A curated, honest guide to mental health and wellbeing resources available to Australians — from free crisis support to paid therapy platforms. Filter by what you need right now.</p>
      </div>
    </div>

    <div class="container">
      <!-- Filter Bar -->
      <div class="filter-bar" role="tablist">
        {filters.map(f => (
          <button
            class="filter-btn active"
            data-filter={f.id}
            role="tab"
            aria-selected="true"
          >
            {f.label}
          </button>
        ))}
      </div>

      <!-- Resource Grid -->
      <div class="resources-grid" id="resources-grid">
        {resources.map(r => (
          <div
            class="resource-card"
            data-category={r.category}
          >
            <div class="card-top">
              <div class="card-meta">
                <span class="category-tag" style={`background: ${categoryColors[r.category]}`}>
                  {r.category === "crisis" ? "Crisis" :
                   r.category === "therapy" ? "Therapy" :
                   r.category === "apps" ? "App" :
                   "Free"}
                </span>
                {r.au && <span class="au-tag">🇦🇺 AU</span>}
                {r.affiliate && <span class="affiliate-tag">Affiliate</span>}
              </div>
              <h2>{r.name}</h2>
              <p class="card-description">{r.description}</p>
            </div>

            <div class="card-bottom">
              <div class="card-info">
                <span class="cost-badge">{r.cost}</span>
                <span class="note-text">{r.note}</span>
              </div>
              <a href={r.url} target="_blank" rel="noopener noreferrer" class="cta-link">
                {r.cta} →
              </a>
            </div>

            {r.affiliate && r.affiliateNote && (
              <p class="affiliate-note">* {r.affiliateNote}</p>
            )}
          </div>
        ))}
      </div>

      <!-- Empty state -->
      <div class="empty-state" id="empty-state" style="display:none;">
        <p>No resources in this category yet. Check back soon.</p>
      </div>
    </div>

    <!-- Disclaimer -->
    <div class="container" style="padding-bottom: 3rem;">
      <div class="disclaimer-box">
        <p><strong>Important:</strong> This directory is for informational purposes only. If you or someone you know is in crisis, please call Lifeline (13 11 14) immediately. This directory does not constitute medical advice. Our affiliate relationships do not influence the honesty of our recommendations.</p>
      </div>
    </div>
  </div>
</Layout>

<style>
  .directory-page {
    padding-bottom: 2rem;
  }

  .hero {
    background: #FAFAFA;
    background-image: radial-gradient(ellipse at top, #F0F4FF 0%, #FAFAFA 60%);
    padding: 4rem 0 3rem;
    text-align: center;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 2.5rem;
  }

  .hero .section-label {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-primary);
    margin-bottom: 0.5rem;
    display: block;
  }

  .hero h1 {
    font-size: 2.4rem;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
  }

  .hero p {
    color: var(--color-text-muted);
    font-size: 1.05rem;
    max-width: 580px;
    margin: 0 auto;
    line-height: 1.7;
  }

  /* Filter bar */
  .filter-bar {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 2rem;
  }

  .filter-btn {
    padding: 0.5rem 1.25rem;
    border-radius: 20px;
    border: 1.5px solid var(--color-border);
    background: white;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-text-muted);
    cursor: pointer;
    transition: all 0.2s;
    font-family: var(--font-body);
  }

  .filter-btn:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  .filter-btn.active {
    background: var(--color-primary);
    border-color: var(--color-primary);
    color: white;
  }

  /* Resource grid */
  .resources-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.25rem;
    margin-bottom: 2rem;
  }

  .resource-card {
    background: white;
    border: 1px solid var(--color-border);
    border-radius: 14px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    transition: box-shadow 0.2s, border-color 0.2s;
  }

  .resource-card:hover {
    box-shadow: 0 4px 20px rgba(0,0,0,0.07);
    border-color: var(--color-primary);
  }

  .resource-card[data-category="crisis"] {
    border-left: 3px solid #DC2626;
  }

  .resource-card[data-category="therapy"] {
    border-left: 3px solid #4F46E5;
  }

  .resource-card[data-category="apps"] {
    border-left: 3px solid #059669;
  }

  .resource-card[data-category="free"] {
    border-left: 3px solid #D97706;
  }

  .card-top {
    margin-bottom: 1.25rem;
  }

  .card-meta {
    display: flex;
    gap: 0.4rem;
    align-items: center;
    margin-bottom: 0.6rem;
    flex-wrap: wrap;
  }

  .category-tag {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: white;
    padding: 0.2rem 0.6rem;
    border-radius: 20px;
  }

  .au-tag {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-text-muted);
  }

  .affiliate-tag {
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-accent);
    border: 1px solid var(--color-accent);
    padding: 0.15rem 0.5rem;
    border-radius: 20px;
  }

  .resource-card h2 {
    font-family: var(--font-body);
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    color: #111827;
  }

  .card-description {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  .card-bottom {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .card-info {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .cost-badge {
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--color-primary);
  }

  .note-text {
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  .cta-link {
    display: inline-block;
    background: var(--color-primary);
    color: white;
    padding: 0.6rem 1.2rem;
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.875rem;
    text-align: center;
    transition: background 0.2s;
    text-decoration: none;
  }

  .cta-link:hover {
    background: var(--color-primary-dark);
    text-decoration: none;
  }

  .affiliate-note {
    font-size: 0.72rem;
    color: var(--color-text-muted);
    font-style: italic;
    margin-top: 0.75rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--color-border);
  }

  /* Empty state */
  .empty-state {
    text-align: center;
    padding: 3rem;
    color: var(--color-text-muted);
  }

  /* Disclaimer */
  .disclaimer-box {
    background: #F3F4F6;
    border-radius: 10px;
    padding: 1.25rem;
    margin-top: 2rem;
    font-size: 0.8rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }
</style>

<script>
  const filterBtns = document.querySelectorAll('.filter-btn');
  const cards = document.querySelectorAll('.resource-card');
  const emptyState = document.getElementById('empty-state');

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      // Update active
      filterBtns.forEach(b => {
        b.classList.remove('active');
        b.setAttribute('aria-selected', 'false');
      });
      btn.classList.add('active');
      btn.setAttribute('aria-selected', 'true');

      const filter = btn.getAttribute('data-filter');
      let visibleCount = 0;

      cards.forEach(card => {
        const category = card.getAttribute('data-category');
        if (filter === 'all' || category === filter) {
          (card as HTMLElement).style.display = '';
          visibleCount++;
        } else {
          (card as HTMLElement).style.display = 'none';
        }
      });

      emptyState.style.display = visibleCount === 0 ? 'block' : 'none';
    });
  });
</script>
