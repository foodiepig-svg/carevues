---
import Layout from '../layouts/Layout.astro';

const posts = [
  {
    title: "How to Prepare for Your First BetterHelp Session — A Practical Guide",
    description: "First BetterHelp session coming up? Here's how to prepare — practical tips on tech, what to expect, and how to get the most out of your first therapy appointment.",
    category: "Mental Health",
    date: "April 27, 2025",
    slug: "how-to-prepare-for-first-betterhelp-session"
  },
  {
    title: "BetterHelp Australia 2025 — Full Honest Review",
    description: "Everything you need to know about BetterHelp in Australia: pricing, how it works, therapist quality, and whether it's actually worth it.",
    category: "Mental Health",
    date: "April 26, 2025",
    slug: "betterhelp-australia-review"
  },
  {
    title: "Best Online Therapy Platforms in Australia (2025 Ranking)",
    description: "We ranked the top 7 online therapy platforms available in Australia — BetterHelp, Talkspace, and 5 others — by price, quality, and features.",
    category: "Mental Health",
    date: "April 26, 2025",
    slug: "best-online-therapy-australia"
  },
  {
    title: "BetterHelp vs Talkspace: Which Is Better for Australians? (2025)",
    description: "We compare BetterHelp and Talkspace side-by-side for Australian users — pricing, therapist quality, features, and which platform actually delivers better value.",
    category: "Mental Health",
    date: "April 27, 2025",
    slug: "betterhelp-vs-talkspace"
  },
  {
    title: "How Much Does BetterHelp Cost in Australia? (2025 Pricing)",
    description: "A complete breakdown of BetterHelp's Australian pricing — weekly costs, plan differences, available discounts, and how it compares to in-person therapy.",
    category: "Mental Health",
    date: "April 26, 2025",
    slug: "betterhelp-cost-australia"
  }
];
---

<Layout>
  <section class="hero">
    <div class="container">
      <h1>Mental Health & Sleep, Honestly Reviewed</h1>
      <p>Carevues helps Australians find the right mental health and wellness products — with no fluff, no hidden agenda, just real reviews and affiliate-supported recommendations.</p>
      <a href="/blog" class="cta-button">Read the Reviews</a>
    </div>
  </section>

  <!-- Problem Section -->
  <section class="problem-section">
    <div class="container">
      <p class="section-label">The Problem</p>
      <h2 class="problem-heading">Australians are struggling. The system isn't keeping up.</h2>

      <div class="stats-grid">
        <div class="stat-card">
          <span class="stat-number">1 in 5</span>
          <span class="stat-desc">Australians experience a mental health condition each year. That's over 5 million people. <em>(ABS, 2023)</em></span>
        </div>
        <div class="stat-card">
          <span class="stat-number">3–4 weeks</span>
          <span class="stat-desc">Average wait time to see a psychologist in Australia — even longer in regional areas. <em>(BeyondBlue)</em></span>
        </div>
        <div class="stat-card">
          <span class="stat-number">$150–280</span>
          <span class="stat-desc">Cost per private psychology session. With no Medicare plan, therapy is out of reach for many. <em>(Psychology Today AU)</em></span>
        </div>
        <div class="stat-card">
          <span class="stat-number">1 in 3</span>
          <span class="stat-desc">Australians don't get enough sleep. Poor sleep is directly linked to anxiety and depression. <em>(Sleep Health Foundation)</em></span>
        </div>
      </div>

      <p class="problem-body">
        The mental health system in Australia is stretched. Bulk-billed psychology is increasingly hard to find. Private therapy is effective but expensive. And online platforms — BetterHelp, Talkspace, and dozens of others — have appeared with promises of accessible, affordable care.
      </p>
      <p class="problem-body">
        The problem: <strong>it's hard to know which platforms actually work, which are worth the money, and which are just marketing.</strong>
      </p>
    </div>
  </section>

  <!-- Solution Section -->
  <section class="solution-section">
    <div class="container">
      <p class="section-label">Why Carevues Exists</p>
      <h2>We cut through the noise.</h2>
      <p class="solution-body">
        Carevues exists because we were frustrated, like many Australians, with having to figure this out alone. We spent weeks researching platforms, reading reviews, comparing prices, and trying things ourselves.
      </p>
      <p class="solution-body">
        We created this site so you don't have to. Every platform we review, we actually look at. Every price we quote, we verify. Every affiliate link we use, we only put on products we'd recommend to a friend.
      </p>
      <p class="solution-body">
        We earn a commission when you use our links — that's how the site stays running. But it <strong>never affects what we say</strong>. If a platform is bad, we'll tell you. If a free option is better, we'll say so.
      </p>
    </div>
  </section>

  <!-- What We Cover -->
  <section class="coverage-section">
    <div class="container">
      <p class="section-label">What We Cover</p>
      <h2>Two areas. Done properly.</h2>
      <div class="coverage-grid">
        <div class="coverage-card">
          <div class="coverage-icon">🧠</div>
          <h3>Mental Health</h3>
          <p>Online therapy platforms, telehealth services, mental health apps, and wellness tools available to Australians. We've reviewed the main players honestly.</p>
        </div>
        <div class="coverage-card">
          <div class="coverage-icon">😴</div>
          <h3>Sleep</h3>
          <p>Sleep trackers, smart mattresses, wearables, and supplements. The science behind what's worth it and what isn't — for Australian sleepers.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Articles -->
  <section class="articles-section">
    <div class="container">
      <p class="section-label">Latest</p>
      <h2 class="section-title">Recently Published</h2>

      {posts.map(post => (
        <a href={`/blog/${post.slug}`} class="article-card">
          <p class="category">{post.category}</p>
          <h2>{post.title}</h2>
          <p>{post.description}</p>
          <p class="meta">{post.date}</p>
        </a>
      ))}
    </div>
  </section>
</Layout>
