<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Carevues — Better mental health and better sleep, for Australians. Honest reviews of online therapy, health tech, and wellness products." />
    <title>Carevues — Mental Health & Sleep Reviews for Australians</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@700&display=swap" rel="stylesheet" />
    <link rel="icon" type="image/png" href="/images/favicon.png" />
  </head>
  <body>
    <nav>
      <div class="container">
        <a href="/" class="logo-link">
          <img src="/images/logo-cropped.png" alt="Carevues" height="40" />
        </a>
        <ul>
          <li><a href="/">Home</a></li>
          <li><a href="/blog">Blog</a></li>
          <li><a href="/about">About</a></li>
        </ul>
      </div>
    </nav>
    <slot />
    <footer>
      <div class="container">
        <p>Carevues.com.au — Honest health and wellness reviews for Australians.</p>
        <p style="margin-top: 0.5rem; font-size: 0.8rem; color: var(--color-text-muted);">We may earn a commission from qualifying purchases. <a href="/about#affiliate-disclosure">Our affiliate disclosure →</a></p>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    --color-primary: #4F46E5;
    --color-primary-dark: #3730A3;
    --color-accent: #F59E0B;
    --color-bg: #FAFAFA;
    --color-surface: #FFFFFF;
    --color-text: #1F2937;
    --color-text-muted: #6B7280;
    --color-border: #E5E7EB;
    --font-body: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    --font-heading: 'Playfair Display', Georgia, serif;
    --max-width: 720px;
  }

  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    font-family: var(--font-body);
    font-size: 17px;
    line-height: 1.7;
    color: var(--color-text);
    background: var(--color-bg);
    -webkit-font-smoothing: antialiased;
  }

  body {
    min-height: 100vh;
  }

  a {
    color: var(--color-primary);
    text-decoration: none;
  }

  a:hover {
    text-decoration: underline;
  }

  img {
    max-width: 100%;
    height: auto;
  }

  h1, h2, h3, h4 {
    font-family: var(--font-heading);
    line-height: 1.2;
    color: #111827;
  }

  .container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* Navigation */
  nav {
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
    padding: 0.75rem 0;
  }

  nav .container {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  nav .logo-link img {
    height: 40px;
    width: auto;
    display: block;
  }

  nav ul {
    list-style: none;
    display: flex;
    gap: 1.5rem;
  }

  nav ul li a {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    font-weight: 500;
  }

  nav ul li a:hover,
  nav ul li a.active {
    color: var(--color-primary);
    text-decoration: none;
  }

  /* Hero */
  .hero {
    background: var(--color-surface);
    padding: 4rem 0;
    text-align: center;
    border-bottom: 1px solid var(--color-border);
  }

  .hero h1 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }

  .hero p {
    color: var(--color-text-muted);
    font-size: 1.1rem;
    max-width: 480px;
    margin: 0 auto 2rem;
  }

  .hero .cta-button {
    display: inline-block;
    background: var(--color-primary);
    color: white;
    padding: 0.75rem 1.75rem;
    border-radius: 8px;
    font-weight: 600;
    font-size: 1rem;
    transition: background 0.2s;
  }

  .hero .cta-button:hover {
    background: var(--color-primary-dark);
    text-decoration: none;
  }

  /* Articles list */
  .articles-section {
    padding: 3rem 0;
  }

  .section-label {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-primary);
    margin-bottom: 0.5rem;
  }

  .section-title {
    font-size: 1.5rem;
    margin-bottom: 2rem;
    font-family: var(--font-body);
    font-weight: 700;
  }

  .article-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 1.5rem;
    margin-bottom: 1rem;
    transition: box-shadow 0.2s, border-color 0.2s;
  }

  .article-card:hover {
    box-shadow: 0 4px 16px rgba(0,0,0,0.06);
    border-color: var(--color-primary);
    text-decoration: none;
  }

  .article-card .category {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-accent);
    margin-bottom: 0.4rem;
  }

  .article-card h2 {
    font-family: var(--font-body);
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .article-card p {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  .article-card .meta {
    margin-top: 0.75rem;
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  /* Single article */
  .article-body {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
  }

  .article-header {
    margin-bottom: 2.5rem;
  }

  .article-header .category {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-primary);
    margin-bottom: 0.75rem;
    display: block;
  }

  .article-header h1 {
    font-size: 2rem;
    margin-bottom: 1rem;
  }

  .article-header .description {
    font-size: 1.1rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  .article-content h2 {
    font-family: var(--font-body);
    font-size: 1.3rem;
    font-weight: 700;
    margin: 2.5rem 0 1rem;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border);
  }

  .article-content h3 {
    font-family: var(--font-body);
    font-size: 1.1rem;
    font-weight: 700;
    margin: 1.5rem 0 0.75rem;
  }

  .article-content p {
    margin-bottom: 1.25rem;
  }

  .article-content ul, .article-content ol {
    margin: 1rem 0 1.5rem 1.5rem;
  }

  .article-content li {
    margin-bottom: 0.5rem;
  }

  .article-content table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
    font-size: 0.9rem;
  }

  .article-content th {
    background: #F3F4F6;
    padding: 0.75rem 1rem;
    text-align: left;
    font-weight: 600;
    border: 1px solid var(--color-border);
  }

  .article-content td {
    padding: 0.75rem 1rem;
    border: 1px solid var(--color-border);
  }

  .article-content tr:nth-child(even) td {
    background: #F9FAFB;
  }

  .article-content strong {
    font-weight: 600;
  }

  .article-content .affiliate-disclosure {
    margin-top: 3rem;
    padding: 1rem;
    background: #F3F4F6;
    border-radius: 8px;
    font-size: 0.8rem;
    color: var(--color-text-muted);
    font-style: italic;
  }

  .cta-box {
    background: linear-gradient(135deg, #EEF2FF 0%, #E0E7FF 100%);
    border: 1px solid #C7D2FE;
    border-radius: 12px;
    padding: 1.5rem;
    margin: 2rem 0;
    text-align: center;
  }

  .cta-box a {
    display: inline-block;
    background: var(--color-primary);
    color: white;
    padding: 0.75rem 1.75rem;
    border-radius: 8px;
    font-weight: 600;
    margin-top: 0.75rem;
    transition: background 0.2s;
  }

  .cta-box a:hover {
    background: var(--color-primary-dark);
    text-decoration: none;
  }

  /* Footer */
  footer {
    background: var(--color-surface);
    border-top: 1px solid var(--color-border);
    padding: 2rem 0;
    margin-top: 3rem;
    text-align: center;
  }

  footer p {
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  /* Hero image */
  .article-hero-image {
    width: 100%;
    max-height: 380px;
    object-fit: cover;
    border-radius: 12px;
    margin-bottom: 2rem;
  }

  /* Responsive */
  @media (max-width: 600px) {
    .hero h1 { font-size: 1.8rem; }
    .hero { padding: 2.5rem 0; }
    nav ul { gap: 1rem; }
    .article-header h1 { font-size: 1.5rem; }
    nav .logo-link img { height: 32px; }
  }
</style>
